{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@ccic/shared-types": ["../../packages/shared-types/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "../../packages/shared-types/src/index.ts"]
}
